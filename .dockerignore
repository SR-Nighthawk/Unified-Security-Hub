# в”Ђв”Ђ Git в”Ђв”Ђ
.git
.gitignore

# в”Ђв”Ђ Python в”Ђв”Ђ
__pycache__
*.pyc
*.pyo
*.egg-info
venv/
.venv/
.pytest_cache/

# в”Ђв”Ђ Environment (NEVER bake secrets into images) в”Ђв”Ђ
.env

# в”Ђв”Ђ IDE / OS в”Ђв”Ђ
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# в”Ђв”Ђ Database (will be mounted as volume) в”Ђв”Ђ
database/*.db

# в”Ђв”Ђ Generated Reports (will be mounted as volume) в”Ђв”Ђ
backend/reports/*.json
backend/reports/*.html
backend/reports/*.pdf
backend/reports/screenshots/

# в”Ђв”Ђ Sessions (will be mounted as volume) в”Ђв”Ђ
backend/sessions/*.json

# в”Ђв”Ђ Static proof screenshots в”Ђв”Ђ
static/proof_*.png
static/screenshots/

# в”Ђв”Ђ PDFs / Large files в”Ђв”Ђ
*.pdf
response.html

# в”Ђв”Ђ Docker / CI в”Ђв”Ђ
docker-compose.yml
docker-compose*.yml
nginx/

# в”Ђв”Ђ Test / Dev files в”Ђв”Ђ
_live_smoke_test.py
refactor_*.py
