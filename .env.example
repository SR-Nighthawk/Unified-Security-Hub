# ═══════════════════════════════════════════════════════════════
# Unified Security Hub — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── AI API Keys ───────────────────────────────────────────────
# Google Gemini (Required for AI Chat & Pentest engine)
GEMINI_API_KEY=

# NVIDIA NIM (Optional fallback for AI Chat)
NVIDIA_API_KEY=

# ── Ransomware Intelligence ───────────────────────────────────
RANSOMWARE_LIVE_API_KEY=
RANSOMWARE_LIVE_BASE_URL=https://api-pro.ransomware.live

# ── External Threat Intel ─────────────────────────────────────
SHODAN_API_KEY=
VULNERS_API_KEY=

# ── Telegram Alerts (Optional) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Metasploit RPC (Optional) ─────────────────────────────────
MSF_RPC_PASS=msfpassword

# ── Tor Proxy (Docker: use container name "tor") ──────────────
TOR_PROXY_HOST=tor
TOR_PROXY_PORT=9050

# ── ZAP Configuration ────────────────────────────────────────
# Docker: ZAP runs in a separate container with API access
ZAP_API_URL=http://zap:8080
ZAP_API_KEY=

# Local development: path to ZAP executable
# ZAP_PATH=C:\Program Files\ZAP\Zed Attack Proxy\ZAP.exe

# ── Nmap Path (auto-detected, override if needed) ─────────────
# NMAP_PATH=/usr/bin/nmap

# ── Gunicorn ──────────────────────────────────────────────────
# LOG_LEVEL=info
# GUNICORN_BIND=0.0.0.0:5000
